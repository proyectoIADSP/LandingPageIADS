---
import { church } from '../../data/church';
---

<section class="section-pad relative overflow-hidden bg-slate-50" id="familia">
  <div class="pointer-events-none absolute top-0 left-1/4 h-96 w-96 rounded-full bg-yellow-300/10 blur-3xl" aria-hidden="true"></div>
  <div class="pointer-events-none absolute right-1/4 bottom-0 h-96 w-96 rounded-full bg-blue-300/10 blur-3xl" aria-hidden="true"></div>

  <div class="container-page relative">
    <div class="reveal mx-auto mb-12 max-w-2xl text-center">
      <p class="section-kicker justify-center">
        {church.sections.familia.kicker}
      </p>
      <h2 class="section-title">
        {church.sections.familia.title}
      </h2>
      <p class="section-lead">
        Conoce a quienes sirven en la {church.name} y el cargo que desempeñan con amor.
        Si deseas involucrarte, serás bienvenido.
      </p>
    </div>

    {
      church.departments.length > 0 && (
        <ul class="reveal mb-8 m-0 grid list-none grid-cols-1 gap-4 p-0 sm:mb-12 sm:gap-5 md:grid-cols-3">
          {church.departments.map((dept, index) => (
            <li class="surface-card group p-5 sm:p-6">
              <span class="mb-4 inline-flex h-8 w-8 items-center justify-center rounded-full bg-navy font-ceremony text-xs font-bold text-gold-soft">
                {String(index + 1).padStart(2, '0')}
              </span>
              <h3 class="mb-2 font-display text-base font-bold text-slate-900 transition-colors group-hover:text-navy sm:text-lg">
                {dept.name}
              </h3>
              <p class="text-sm leading-relaxed text-slate-600">{dept.summary}</p>
            </li>
          ))}
        </ul>
      )
    }

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3 xl:grid-cols-4">
      {
        church.ministries.map((ministry, index) => (
          <article
            class="group surface-card reveal flex items-start gap-3 p-4 sm:gap-4 sm:p-5"
            style={`transition-delay: ${index * 35}ms`}
          >
            <span
              class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-gold-soft to-white font-ceremony text-sm font-bold text-gold-deep ring-2 ring-gold/25 transition-transform duration-300 group-hover:scale-105 sm:h-12 sm:w-12"
              aria-hidden="true"
            >
              {ministry.leader.charAt(0)}
            </span>
            <div class="min-w-0 pt-0.5">
              <h3 class="mb-1 font-display text-base font-bold text-slate-900 transition-colors duration-300 group-hover:text-navy sm:text-lg">
                {ministry.leader}
              </h3>
              <p class="text-sm leading-snug text-slate-600">{ministry.role}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
