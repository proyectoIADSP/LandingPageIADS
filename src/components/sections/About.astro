---
import { Image } from 'astro:assets';
import { church } from '../../data/church';
import nosotrosPrincipal from '../../assets/Nosotros_iglesiapariachi.jpg';
import nosotros1 from '../../assets/nosotros 1.jpeg';
import nosotros2 from '../../assets/nosotros 2.jpeg';
import nosotros3 from '../../assets/nosotros 3.jpeg';
import nosotros4 from '../../assets/nosotros 4.jpeg';
import nosotros5 from '../../assets/nosotros 5.jpeg';
import nosotros6 from '../../assets/nosotros 6.jpeg';

const gallery = [
  { src: nosotrosPrincipal, alt: `Familia de la ${church.name}` },
  { src: nosotros1, alt: `Congregación de la ${church.name} — momento 1` },
  { src: nosotros2, alt: `Congregación de la ${church.name} — momento 2` },
  { src: nosotros3, alt: `Congregación de la ${church.name} — momento 3` },
  { src: nosotros4, alt: `Congregación de la ${church.name} — momento 4` },
  { src: nosotros5, alt: `Congregación de la ${church.name} — momento 5` },
  { src: nosotros6, alt: `Congregación de la ${church.name} — momento 6` },
];
---

<section class="section-pad relative overflow-hidden bg-slate-50" id="nosotros">
  <div class="pointer-events-none absolute top-0 left-1/4 h-96 w-96 rounded-full bg-yellow-300/10 blur-3xl" aria-hidden="true"></div>
  <div class="pointer-events-none absolute right-1/4 bottom-0 h-96 w-96 rounded-full bg-blue-300/10 blur-3xl" aria-hidden="true"></div>

  <div class="container-page relative">
    <div class="reveal mx-auto mb-10 max-w-2xl text-center">
      <p class="section-kicker justify-center">
        {church.sections.about.kicker}
      </p>
      <h2 class="section-title mb-4">
        {church.sections.about.title}
      </h2>
      <p class="text-pretty text-sm text-slate-600 sm:text-base md:text-lg">
        Somos la familia de la {church.name}: una comunidad de fe en {church.location}.
      </p>
    </div>

    <div
      class="reveal group relative mb-6 aspect-[16/10] overflow-hidden rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] sm:mb-8 sm:aspect-[21/9]"
      data-about-carousel
      role="region"
      aria-roledescription="carrusel"
      aria-label={`Galería de la ${church.name}`}
    >
      {
        gallery.map((photo, index) => (
          <div
            class:list={[
              'absolute inset-0 transition-opacity duration-1000 ease-in-out',
              index === 0 ? 'opacity-100 z-[1]' : 'opacity-0 z-0',
            ]}
            data-about-slide
            aria-hidden={index === 0 ? 'false' : 'true'}
          >
            <Image
              src={photo.src}
              alt={photo.alt}
              widths={[480, 720, 1080, 1440, 1920]}
              sizes="(max-width: 640px) 100vw, (max-width: 1120px) 100vw, 1120px"
              quality={90}
              loading={index === 0 ? 'eager' : 'lazy'}
              class="h-full w-full object-cover"
            />
          </div>
        ))
      }

      <div
        class="pointer-events-none absolute inset-x-0 bottom-0 z-[2] bg-gradient-to-t from-navy-deep/70 via-navy-deep/20 to-transparent px-4 pb-12 pt-16 sm:px-5 sm:pb-14 sm:pt-20 md:px-8"
        aria-hidden="true"
      >
        <p class="font-display text-base text-white italic sm:text-lg md:text-xl">
          Nuestra familia en {church.location}
        </p>
      </div>

      <button
        type="button"
        class="absolute top-1/2 left-3 z-[3] flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full border border-white/30 bg-white/20 text-white opacity-70 backdrop-blur-md transition-all duration-300 hover:bg-white/30 hover:opacity-100 focus:opacity-100 focus:outline-none focus-visible:ring-2 focus-visible:ring-gold sm:left-4 sm:h-11 sm:w-11 md:opacity-0 md:group-hover:opacity-100"
        data-about-prev
        aria-label="Foto anterior"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>

      <button
        type="button"
        class="absolute top-1/2 right-3 z-[3] flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full border border-white/30 bg-white/20 text-white opacity-70 backdrop-blur-md transition-all duration-300 hover:bg-white/30 hover:opacity-100 focus:opacity-100 focus:outline-none focus-visible:ring-2 focus-visible:ring-gold sm:right-4 sm:h-11 sm:w-11 md:opacity-0 md:group-hover:opacity-100"
        data-about-next
        aria-label="Foto siguiente"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>

      <div
        class="absolute inset-x-0 bottom-4 z-[3] flex items-center justify-center gap-2 sm:bottom-5"
        data-about-dots
        role="tablist"
        aria-label="Seleccionar foto"
      >
        {
          gallery.map((_, index) => (
            <button
              type="button"
              class:list={[
                'h-2 w-2 rounded-full transition-all duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2 focus-visible:ring-offset-navy-deep',
                index === 0 ? 'scale-125 bg-gold' : 'bg-white/40 hover:bg-white/70',
              ]}
              data-about-dot={index}
              aria-label={`Ir a la foto ${index + 1}`}
              aria-selected={index === 0 ? 'true' : 'false'}
              role="tab"
            />
          ))
        }
      </div>
    </div>

    <div class="reveal relative z-10 mx-auto -mt-1 grid max-w-5xl gap-4 sm:gap-5 md:-mt-10 md:grid-cols-[1.15fr_0.85fr]">
      <article class="surface-card p-5 sm:p-6 md:p-8">
        <div class="mb-5 flex items-center gap-3">
          <span class="h-10 w-1.5 shrink-0 rounded-full bg-gold"></span>
          <p class="font-ceremony text-[0.65rem] font-semibold tracking-[0.16em] text-gold-deep uppercase sm:text-xs sm:tracking-[0.18em]">
            Una invitación para ti
          </p>
        </div>

        <p class="mb-6 font-display text-lg leading-snug font-semibold tracking-tight text-pretty text-slate-900 sm:text-xl md:text-2xl">
          {church.invitation}
        </p>

        <blockquote class="mb-6 rounded-2xl border border-gold/20 bg-gradient-to-br from-gold-soft/70 to-white/90 p-4 ring-1 ring-inset ring-white/50 sm:p-5 md:p-6">
          <p class="mb-3 font-display text-base leading-relaxed text-navy italic sm:text-lg md:text-xl">
            “{church.verse.text}”
          </p>
          <cite class="font-ceremony text-[0.65rem] font-semibold tracking-[0.14em] text-gold-deep uppercase not-italic sm:text-xs sm:tracking-[0.16em]">
            {church.verse.reference}
          </cite>
        </blockquote>

        <p class="mb-7 text-sm leading-relaxed text-pretty text-slate-600 sm:text-base">
          En la IASD Pariachi creemos que la iglesia no es solo un edificio: es la casa de Dios, un hogar espiritual donde cada persona puede orar, aprender y caminar con Jesús en comunidad.
        </p>

        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a class="btn-primary" href={church.beliefsUrl} target="_blank" rel="noopener noreferrer">
            {church.beliefsLabel}
          </a>
          <a class="btn-secondary" href="#horarios">Ver horarios</a>
        </div>
      </article>

      <aside class="grid gap-4">
        {
          church.highlights.map((item) => (
            <div class="group surface-card p-5">
              <div class="mb-3 flex items-center gap-3">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gold-soft font-ceremony text-sm font-bold text-gold-deep transition-transform duration-300 group-hover:scale-105">
                  {item.title.charAt(0)}
                </span>
                <h3 class="font-display text-lg font-bold text-slate-900">{item.title}</h3>
              </div>
              <p class="text-sm leading-relaxed text-slate-600">{item.text}</p>
            </div>
          ))
        }

        <div class="relative overflow-hidden rounded-2xl bg-navy-deep p-5 text-white shadow-[0_8px_30px_rgb(0,0,0,0.08)] ring-1 ring-inset ring-white/10 transition-all duration-300 ease-out hover:-translate-y-2 hover:shadow-[0_20px_40px_rgb(0,0,0,0.16)]">
          <p class="mb-2 font-ceremony text-[0.7rem] font-semibold tracking-[0.18em] text-gold-soft uppercase">
            Bienvenido a casa
          </p>
          <p class="mb-4 font-display text-lg leading-snug">
            Aquí hay un lugar para ti, tu familia y tu fe.
          </p>
          <a class="btn-primary w-full" href="#ubicacion">Visítanos este sábado</a>
        </div>
      </aside>
    </div>
  </div>
</section>

<script>
  function initAboutCarousel() {
    const root = document.querySelector('[data-about-carousel]');
    if (!(root instanceof HTMLElement) || root.dataset.ready === '1') return;
    root.dataset.ready = '1';

    const slides = Array.from(root.querySelectorAll('[data-about-slide]'));
    const dots = Array.from(root.querySelectorAll('[data-about-dot]'));
    const prevBtn = root.querySelector('[data-about-prev]');
    const nextBtn = root.querySelector('[data-about-next]');
    if (slides.length < 2) return;

    let index = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    const INTERVAL_MS = 4000;

    function show(next: number) {
      index = (next + slides.length) % slides.length;

      slides.forEach((slide, i) => {
        const active = i === index;
        slide.classList.toggle('opacity-100', active);
        slide.classList.toggle('z-[1]', active);
        slide.classList.toggle('opacity-0', !active);
        slide.classList.toggle('z-0', !active);
        slide.setAttribute('aria-hidden', active ? 'false' : 'true');
      });

      dots.forEach((dot, i) => {
        const active = i === index;
        dot.classList.toggle('bg-gold', active);
        dot.classList.toggle('scale-125', active);
        dot.classList.toggle('bg-white/40', !active);
        dot.setAttribute('aria-selected', active ? 'true' : 'false');
      });
    }

    function stop() {
      if (timer) {
        clearInterval(timer);
        timer = null;
      }
    }

    function start() {
      stop();
      timer = setInterval(() => show(index + 1), INTERVAL_MS);
    }

    function goTo(next: number) {
      show(next);
      start();
    }

    prevBtn?.addEventListener('click', () => goTo(index - 1));
    nextBtn?.addEventListener('click', () => goTo(index + 1));

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        goTo(Number(dot.getAttribute('data-about-dot') || 0));
      });
    });

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    root.addEventListener('focusin', stop);
    root.addEventListener('focusout', (event) => {
      if (!root.contains(event.relatedTarget as Node | null)) start();
    });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop();
      else start();
    });

    start();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAboutCarousel);
  } else {
    initAboutCarousel();
  }
</script>
